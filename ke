<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garage Auto BK — Mécanicien mobile Médoc</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0D1B2A;
  --teal:#1A7F6E;
  --teal-light:#E8F5F2;
  --teal-mid:#2DB89E;
  --accent:#F0A500;
  --text:#1C2B39;
  --muted:#5C7080;
  --border:#E4ECF0;
  --bg:#F7FAFB;
  --white:#FFFFFF;
  --r:14px;
  --sh:0 4px 24px rgba(13,27,42,.09);
  --sh2:0 8px 36px rgba(13,27,42,.15);
  --font-title:'Syne',system-ui,sans-serif;
  --font-body:'DM Sans',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--font-body);color:var(--text);background:var(--white);line-height:1.6;-webkit-font-smoothing:antialiased}
 
/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 5vw;display:flex;align-items:center;justify-content:space-between;height:68px}
.logo{font-family:var(--font-title);font-weight:800;font-size:21px;color:var(--navy);text-decoration:none;display:flex;align-items:center;gap:9px}
.logo-box{width:36px;height:36px;background:var(--teal);border-radius:10px;display:flex;align-items:center;justify-content:center}
.logo-box svg{width:20px;height:20px;fill:white}
.nav-links{display:flex;gap:28px;align-items:center}
.nav-links a{text-decoration:none;font-size:15px;color:var(--muted);transition:color .2s}
.nav-links a:hover{color:var(--teal)}
.nav-cta{background:var(--teal);color:white!important;padding:9px 20px;border-radius:8px;font-weight:500;transition:background .2s!important}
.nav-cta:hover{background:#15685A!important}
 
/* HERO */
.hero{background:var(--navy);padding:72px 5vw 0;overflow:hidden;position:relative}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(26,127,110,.22) 0%,transparent 70%);pointer-events:none}
.hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(45,184,158,.15);color:var(--teal-mid);border:1px solid rgba(45,184,158,.3);padding:5px 14px;border-radius:100px;font-size:13px;font-weight:500;margin-bottom:22px}
.hero-badge span{width:6px;height:6px;background:var(--teal-mid);border-radius:50%}
.hero h1{font-family:var(--font-title);font-size:clamp(32px,4.5vw,54px);font-weight:800;color:white;line-height:1.1;margin-bottom:18px}
.hero h1 em{color:var(--teal-mid);font-style:normal}
.hero p{color:rgba(255,255,255,.65);font-size:17px;font-weight:300;margin-bottom:36px}
.search-box{background:white;border-radius:var(--r);padding:8px;display:flex;gap:8px;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.sf{flex:1;display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg);border-radius:9px}
.sf svg{width:18px;height:18px;flex-shrink:0}
.sf input{border:none;background:transparent;font-family:var(--font-body);font-size:15px;color:var(--text);outline:none;width:100%}
.sf input::placeholder{color:var(--muted)}
.search-div{width:1px;background:var(--border);margin:8px 0}
.search-btn{background:var(--teal);color:white;border:none;border-radius:9px;padding:12px 26px;font-family:var(--font-body);font-size:15px;font-weight:500;cursor:pointer;transition:background .2s,transform .1s;white-space:nowrap}
.search-btn:hover{background:#15685A}
.search-btn:active{transform:scale(.98)}
.hero-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:18px}
.htag{color:rgba(255,255,255,.55);font-size:13px;cursor:pointer;padding:4px 12px;border:1px solid rgba(255,255,255,.15);border-radius:100px;transition:all .2s}
.htag:hover{color:white;border-color:rgba(255,255,255,.4)}
.hero-right{}
.hero-stats{display:flex;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:var(--r);overflow:hidden}
.stat-it{flex:1;padding:22px;border-right:1px solid rgba(255,255,255,.12);text-align:center}
.stat-it:last-child{border-right:none}
.stat-n{font-family:var(--font-title);font-size:28px;font-weight:800;color:white;display:block}
.stat-l{color:rgba(255,255,255,.5);font-size:13px}
.hero-visual{margin-top:28px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--r) var(--r) 0 0;padding:18px}
.mc{background:white;border-radius:10px;padding:13px 15px;display:flex;align-items:center;gap:12px;margin-bottom:9px;animation:float 3s ease-in-out infinite}
.mc:nth-child(2){animation-delay:-1.5s}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
.mc-av{width:42px;height:42px;border-radius:9px;background:var(--teal-light);display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0}
.mc-info{flex:1}
.mc-name{font-weight:500;font-size:13px;color:var(--text)}
.mc-sub{font-size:12px;color:var(--muted)}
.mc-stars{color:var(--accent);font-size:12px}
.mc-badge{background:var(--teal-light);color:var(--teal);font-size:11px;font-weight:500;padding:3px 8px;border-radius:100px}
 
/* BRANDS */
.brands{border-bottom:1px solid var(--border);padding:22px 5vw;background:var(--bg);display:flex;align-items:center;justify-content:center;gap:44px;flex-wrap:wrap}
.bl{font-family:var(--font-title);font-weight:700;font-size:14px;color:#B0C4CC;letter-spacing:.5px}
 
/* SECTIONS */
section{padding:76px 5vw}
.sl{font-size:12px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;color:var(--teal);margin-bottom:10px}
.st{font-family:var(--font-title);font-size:clamp(24px,3vw,36px);font-weight:700;color:var(--navy);line-height:1.2;margin-bottom:14px}
.ssub{font-size:17px;color:var(--muted);max-width:540px}
.sh{margin-bottom:52px}
 
/* SERVICES */
.srv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.srv-card{background:white;border:1px solid var(--border);border-radius:var(--r);padding:26px 20px;text-align:center;cursor:pointer;transition:all .2s}
.srv-card:hover{border-color:var(--teal);background:var(--teal-light);transform:translateY(-3px)}
.srv-ico{font-size:34px;margin-bottom:12px}
.srv-name{font-family:var(--font-title);font-weight:600;font-size:14px;color:var(--navy);margin-bottom:5px}
.srv-count{font-size:12px;color:var(--muted)}
 
/* HOW */
.how{background:var(--bg)}
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;max-width:1100px;margin:0 auto}
.step{position:relative;background:white;border-radius:var(--r);padding:32px 26px;border:1px solid var(--border);transition:transform .2s,box-shadow .2s}
.step:hover{transform:translateY(-4px);box-shadow:var(--sh2)}
.step-num{font-family:var(--font-title);font-size:60px;font-weight:800;color:var(--teal-light);line-height:1;margin-bottom:8px}
.step-ico{width:50px;height:50px;border-radius:13px;background:var(--teal-light);display:flex;align-items:center;justify-content:center;margin-bottom:18px;font-size:22px}
.step h3{font-family:var(--font-title);font-size:18px;font-weight:700;color:var(--navy);margin-bottom:9px}
.step p{font-size:15px;color:var(--muted);line-height:1.6}
.step-arr{position:absolute;right:-18px;top:50%;transform:translateY(-50%);width:36px;height:36px;border-radius:50%;background:white;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;color:var(--teal);font-size:16px;z-index:2}
.step:last-child .step-arr{display:none}
 
/* GARAGES */
.filter-bar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px}
.fb{padding:7px 17px;border-radius:100px;border:1.5px solid var(--border);background:white;color:var(--muted);font-family:var(--font-body);font-size:14px;cursor:pointer;transition:all .2s}
.fb.act,.fb:hover{border-color:var(--teal);color:var(--teal);background:var(--teal-light)}
.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.gc{background:white;border-radius:var(--r);border:1px solid var(--border);overflow:hidden;transition:transform .2s,box-shadow .2s;cursor:pointer}
.gc:hover{transform:translateY(-4px);box-shadow:var(--sh2)}
.ci{height:175px;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.ci-1{background:linear-gradient(135deg,#1A7F6E,#0D5246)}
.ci-2{background:linear-gradient(135deg,#1B3A5C,#0D2640)}
.ci-3{background:linear-gradient(135deg,#4A3728,#2C1F16)}
.ci-4{background:linear-gradient(135deg,#1F5C3A,#0F3320)}
.ci-5{background:linear-gradient(135deg,#3D1F5C,#220D3A)}
.ci-6{background:linear-gradient(135deg,#5C3A1A,#3A200A)}
.ci-ico{font-size:46px;opacity:.25}
.cbadge{position:absolute;top:12px;left:12px;background:white;color:var(--teal);font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;display:flex;align-items:center;gap:4px}
.cbd{width:6px;height:6px;background:var(--teal);border-radius:50%}
.cfav{position:absolute;top:12px;right:12px;background:rgba(255,255,255,.9);width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;border:none}
.cbody{padding:18px}
.ch{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:8px}
.cname{font-family:var(--font-title);font-size:16px;font-weight:700;color:var(--navy)}
.crat{display:flex;align-items:center;gap:4px;background:#FFF8E6;border-radius:7px;padding:3px 9px}
.crat .s{color:var(--accent);font-size:13px}
.crat .n{font-weight:600;font-size:13px;color:var(--text)}
.crat .c{font-size:11px;color:var(--muted)}
.cloc{font-size:13px;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:4px}
.ctags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:14px}
.ctag{font-size:11px;color:var(--teal);background:var(--teal-light);padding:3px 9px;border-radius:100px}
.cfoot{display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--border);padding-top:12px}
.cprice{font-size:13px;color:var(--muted)}
.cprice strong{color:var(--text);font-size:14px}
.ccta{background:var(--navy);color:white;border:none;border-radius:7px;padding:8px 16px;font-family:var(--font-body);font-size:13px;font-weight:500;cursor:pointer;transition:background .2s}
.ccta:hover{background:var(--teal)}
 
/* DEVIS */
.devis-section{background:var(--bg)}
.devis-wrap{max-width:700px;margin:0 auto}
.devis-card{background:white;border:1px solid var(--border);border-radius:var(--r);padding:32px;box-shadow:var(--sh)}
.dh{display:flex;align-items:center;gap:14px;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.dh-ico{width:48px;height:48px;border-radius:12px;background:var(--teal);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.dh-ico svg{width:24px;height:24px;fill:white}
.dh h3{font-family:var(--font-title);font-size:19px;font-weight:700;color:var(--navy);margin-bottom:3px}
.dh p{font-size:13px;color:var(--muted)}
.spills{display:flex;gap:0;border-radius:9px;overflow:hidden;border:1px solid var(--border);margin-bottom:24px}
.sp{flex:1;padding:8px;text-align:center;font-size:12px;color:var(--muted);background:var(--bg);border-right:1px solid var(--border);transition:all .2s}
.sp:last-child{border-right:none}
.sp.act{background:white;color:var(--text);font-weight:500}
.sp.done{background:#E1F5EE;color:#085041}
.dfield{margin-bottom:16px}
.dlabel{font-size:13px;color:var(--muted);margin-bottom:6px;display:block}
.drow2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.dinput,.dselect,.dtextarea{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:9px;font-family:var(--font-body);font-size:14px;color:var(--text);outline:none;background:white;transition:border-color .2s}
.dinput:focus,.dselect:focus,.dtextarea:focus{border-color:var(--teal)}
.dtextarea{resize:vertical;min-height:80px;line-height:1.5}
.chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:6px}
.chip{padding:7px 14px;border-radius:100px;border:1.5px solid var(--border);background:white;font-family:var(--font-body);font-size:13px;color:var(--text);cursor:pointer;transition:all .15s}
.chip:hover,.chip.sel{border-color:var(--teal);background:var(--teal-light);color:var(--teal)}
.chip.sel{font-weight:500}
.dbtn{width:100%;padding:13px;background:var(--teal);color:white;border:none;border-radius:9px;font-family:var(--font-body);font-size:15px;font-weight:500;cursor:pointer;margin-top:8px;transition:background .2s}
.dbtn:hover{background:#15685A}
.dbtn:disabled{background:var(--muted);cursor:not-allowed}
.dbtn-sec{background:var(--bg);color:var(--text);border:1px solid var(--border)}
.dbtn-sec:hover{background:var(--border)}
.result-card{background:white;border:1px solid var(--border);border-radius:var(--r);padding:22px;margin-bottom:14px}
.rh{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--border)}
.rh-title{font-family:var(--font-title);font-weight:700;font-size:17px;color:var(--navy)}
.rh-sub{font-size:13px;color:var(--muted)}
.badge-ok{background:var(--teal-light);color:#085041;font-size:12px;font-weight:500;padding:4px 12px;border-radius:100px}
.price-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.pbox{background:var(--bg);border-radius:9px;padding:14px}
.pbox-l{font-size:12px;color:var(--muted);margin-bottom:4px}
.pbox-v{font-size:19px;font-weight:700;color:var(--teal)}
.pbox-v2{font-size:19px;font-weight:700;color:var(--navy)}
.pbox-s{font-size:11px;color:var(--muted);margin-top:2px}
.incl-title{font-size:13px;font-weight:500;color:var(--text);margin-bottom:8px}
.incl-item{display:flex;align-items:flex-start;gap:8px;font-size:13px;color:var(--muted);margin-bottom:5px}
.incl-check{color:var(--teal);flex-shrink:0;font-size:15px}
.divid{height:1px;background:var(--border);margin:14px 0}
.conseil-box{display:flex;align-items:flex-start;gap:10px;background:var(--bg);border-radius:9px;padding:12px;margin-bottom:10px}
.urg-box{display:flex;align-items:flex-start;gap:10px;border-radius:9px;padding:12px;border:1px solid}
.urg-high{background:#FFF0F0;border-color:#F09595;color:#791F1F}
.urg-mod{background:#FFFBF0;border-color:#FAC775;color:#633806}
.urg-low{background:var(--teal-light);border-color:#9FE1CB;color:#085041}
.urg-label{font-size:11px;font-weight:600;margin-bottom:2px}
.urg-text{font-size:13px;line-height:1.5}
.note-box{font-size:12px;color:var(--muted);background:var(--bg);border-radius:8px;padding:10px 14px;margin-top:12px;line-height:1.5}
.loading-box{text-align:center;padding:40px 0;color:var(--muted);font-size:14px}
.spin{width:32px;height:32px;border:2px solid var(--border);border-top-color:var(--teal);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 14px}
@keyframes spin{to{transform:rotate(360deg)}}
 
/* TRUST */
.trust{background:var(--navy)}
.trust-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center;max-width:1100px;margin:0 auto}
.trust .st{color:white}
.trust .ssub{color:rgba(255,255,255,.55)}
.tpoints{list-style:none;margin-top:28px;display:flex;flex-direction:column;gap:14px}
.tp{display:flex;align-items:flex-start;gap:13px;color:rgba(255,255,255,.75);font-size:15px}
.tcheck{width:22px;height:22px;border-radius:50%;background:var(--teal);flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px}
.tcheck svg{width:12px;height:12px;fill:white}
.rev-stack{display:flex;flex-direction:column;gap:14px}
.rev{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:var(--r);padding:20px}
.rev-stars{color:var(--accent);font-size:14px;margin-bottom:10px}
.rev-text{color:rgba(255,255,255,.8);font-size:14px;line-height:1.6;margin-bottom:14px;font-style:italic}
.rev-auth{display:flex;align-items:center;gap:11px}
.rev-av{width:36px;height:36px;border-radius:50%;background:var(--teal);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;color:white}
.rev-name{font-weight:500;font-size:14px;color:white}
.rev-meta{font-size:12px;color:rgba(255,255,255,.4)}
 
/* CTA BAND */
.cta-band{background:var(--teal);padding:64px 5vw;text-align:center}
.cta-band h2{font-family:var(--font-title);font-size:clamp(22px,3vw,38px);font-weight:800;color:white;margin-bottom:14px}
.cta-band p{color:rgba(255,255,255,.7);font-size:17px;margin-bottom:32px}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn-w{background:white;color:var(--teal);border:none;border-radius:9px;padding:13px 30px;font-family:var(--font-body);font-size:15px;font-weight:600;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block}
.btn-w:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
.btn-gh{background:transparent;color:white;border:2px solid rgba(255,255,255,.5);border-radius:9px;padding:13px 30px;font-family:var(--font-body);font-size:15px;font-weight:500;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block}
.btn-gh:hover{border-color:white;background:rgba(255,255,255,.1)}
 
/* FOOTER */
footer{background:var(--navy);padding:56px 5vw 28px;border-top:1px solid rgba(255,255,255,.08)}
.fg{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;max-width:1100px;margin:0 auto 44px}
.fc h4{font-family:var(--font-title);font-size:12px;font-weight:600;color:rgba(255,255,255,.35);letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.fc a{display:block;text-decoration:none;font-size:14px;color:rgba(255,255,255,.55);margin-bottom:9px;transition:color .2s}
.fc a:hover{color:var(--teal-mid)}
.fb-brand p{font-size:14px;color:rgba(255,255,255,.4);line-height:1.7;max-width:250px;margin-top:12px}
.fbot{border-top:1px solid rgba(255,255,255,.08);padding-top:22px;max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between}
.fcopy{font-size:13px;color:rgba(255,255,255,.3)}
.fsocs{display:flex;gap:10px}
.fsoc{width:34px;height:34px;border-radius:7px;border:1px solid rgba(255,255,255,.12);background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;color:rgba(255,255,255,.5);font-size:14px}
.fsoc:hover{border-color:var(--teal-mid);color:var(--teal-mid)}
.view-more{text-align:center;margin-top:36px}
.btn-ol{display:inline-flex;align-items:center;gap:7px;border:1.5px solid var(--navy);color:var(--navy);background:transparent;border-radius:9px;padding:12px 26px;font-family:var(--font-body);font-size:15px;font-weight:500;cursor:pointer;text-decoration:none;transition:all .2s}
.btn-ol:hover{background:var(--navy);color:white}
 
@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr}
  .hero-right{display:none}
  .steps{grid-template-columns:1fr}
  .cards-grid{grid-template-columns:1fr 1fr}
  .srv-grid{grid-template-columns:repeat(2,1fr)}
  .trust-grid{grid-template-columns:1fr}
  .fg{grid-template-columns:1fr 1fr}
  nav .nav-links{display:none}
}
@media(max-width:600px){
  .cards-grid{grid-template-columns:1fr}
  .srv-grid{grid-template-columns:repeat(2,1fr)}
  .search-box{flex-direction:column}
  .search-div{display:none}
  .drow2{grid-template-columns:1fr}
}
</style>
</head>
<body>
 
<!-- NAV -->
<nav>
