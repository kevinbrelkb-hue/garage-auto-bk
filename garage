<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garage Finder</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: radial-gradient(circle at top right, #0f2a3a, #020617);
  color: white;
}

.container {
  display: flex;
  justify-content: space-between;
  padding: 60px;
}

.left {
  max-width: 50%;
}

.badge {
  background: rgba(0,255,200,0.1);
  color: #2dd4bf;
  padding: 8px 15px;
  border-radius: 20px;
  display: inline-block;
  margin-bottom: 20px;
  font-size: 14px;
}

h1 {
  font-size: 60px;
  line-height: 1.1;
}

.highlight {
  color: #2dd4bf;
}

.subtitle {
  color: #94a3b8;
  margin-top: 20px;
}

.search-box {
  margin-top: 30px;
  display: flex;
  background: white;
  border-radius: 15px;
  overflow: hidden;
}

.search-box input {
  border: none;
  padding: 15px;
  flex: 1;
}

.search-box button {
  background: #10b981;
  color: white;
  border: none;
  padding: 15px 25px;
  cursor: pointer;
}

.right {
  width: 40%;
}

.stats {
  display: flex;
  gap: 10px;
}

.stat {
  background: rgba(255,255,255,0.05);
  padding: 20px;
  border-radius: 15px;
  flex: 1;
  text-align: center;
}

.cards {
  margin-top: 20px;
}

.card {
  background: #e5e7eb;
  color: black;
  padding: 15px;
  border-radius: 12px;
  margin-bottom: 10px;
}

.available {
  float: right;
  background: #10b981;
  color: white;
  padding: 5px 10px;
  border-radius: 10px;
  font-size: 12px;
}
</style>
</head>

<body>

<div class="container">

  <div class="left">
    <div class="badge">+1200 garages référencés en France</div>

    <h1>
      Votre mécanicien<br>
      de confiance,<br>
      <span class="highlight">près de vous</span>
    </h1>

    <p class="subtitle">
      Comparez les garages, lisez les avis clients vérifiés
      et prenez rendez-vous en quelques clics.
    </p>

    <div class="search-box">
      <input placeholder="Vidange, freins...">
      <input placeholder="Ville">
      <button onclick="search()">Rechercher</button>
    </div>
  </div>

  <div class="right">

    <div class="stats">
      <div class="stat">
        <h2>1200+</h2>
        <p>Garages</p>
      </div>
      <div class="stat">
        <h2>98%</h2>
        <p>Clients satisfaits</p>
      </div>
      <div class="stat">
        <h2>4.8★</h2>
        <p>Note moyenne</p>
      </div>
    </div>

    <div class="cards" id="results"></div>

  </div>

</div>

<script>
const garages = [
  { name: "Garage Auto BK", city: "Bordeaux", service: "vidange" },
  { name: "Garage du Médoc", city: "Bordeaux", service: "frein" }
];

function search() {
  const container = document.getElementById("results");
  container.innerHTML = "";

  garages.forEach(g => {
    const div = document.createElement("div");
    div.className = "card";

    div.innerHTML = `
      <strong>${g.name}</strong>
      <span class="available">Disponible</span>
      <p>${g.city} - ${g.service}</p>
      ⭐⭐⭐⭐⭐
    `;

    container.appendChild(div);
  });
}
</script>

</body>
</html>
